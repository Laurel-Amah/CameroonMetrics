# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
# Optional override (default: gpt-4o)
# OPENAI_ARTICLE_MODEL=gpt-4o-mini

# Optional: service role for server-only jobs (e.g. FX cron) and local seed scripts — never expose to the browser
# SUPABASE_SERVICE_ROLE_KEY=

# Markets FX: exchangerate.host (free tier) + daily cron — see vercel.json and /api/cron/fx-daily
# EXCHANGERATE_HOST_ACCESS_KEY=
# CRON_SECRET=
